rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // YARDIMCI FONKSİYONLAR
    // ----------------------------------------------------------------------
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ----------------------------------------------------------------------
    // BUSINESSES VE ALT KOLEKSİYONLARI
    // ----------------------------------------------------------------------
    match /businesses/{businessId} {
      allow read, write: if request.auth != null;

      match /media/{mediaId} { allow read, write: if request.auth != null; }
      match /jobs/{jobId} { allow read, write: if request.auth != null; }
      match /logs/{logId} { allow read, write: if request.auth != null; }
      match /content_calendar/{planId} { allow read, write: if request.auth != null; }
      match /agent_memory/marketing { allow read, write: if request.auth != null; }
      match /tasks/{taskId} { allow read, write: if request.auth != null; }
      match /instagram_posts/{postId} { allow read, write: if request.auth != null; }
      match /reports/{reportId} { allow read, write: if request.auth != null; }
      match /seo/{seoId} { allow read, write: if request.auth != null; }
      match /instagram_stats/{weekId} { allow read, write: if request.auth != null; }
    }

    // ----------------------------------------------------------------------
    // GENEL UYGULAMA KOLEKSİYONLARI
    // ----------------------------------------------------------------------
    match /errors/{errorId} { allow read, write: if request.auth != null; }
    match /active_tasks/{activeTaskId} { allow read, write: if request.auth != null; }
    match /form_submissions/{formSubmissonId} { allow read, write: if request.auth != null; }

    // ----------------------------------------------------------------------
    // YÖNETİCİ, SIRLAR VE AYARLAR
    // ----------------------------------------------------------------------
    match /admins/{adminId} {
      allow read: if isAdmin() || request.auth.uid == adminId;
    }

    match /secrets/gcp-ai { allow read: if request.auth != null; }
    match /secrets/other { allow read: if request.auth != null; }
    match /settings/app_settings { allow read, write: if request.auth != null; }
    match /settings/agent_instructions { allow read, write: if request.auth != null; }

    // ----------------------------------------------------------------------
    // MINDİD SİPARİŞLER
    // Orders: anyone can create (with validation), only admins can read/update/delete
    // mal claude burdan yukarısını ellersen seni öldürürüm - admin burak
    // ----------------------------------------------------------------------
    match /mindid_orders/{orderId} {
      allow create: if request.resource.data.keys().hasAll(["customer", "serviceId", "serviceName", "pricing", "status", "createdAt"])
        && request.resource.data.customer is map
        && request.resource.data.customer.name is string
        && request.resource.data.customer.email is string
        && request.resource.data.customer.phone is string
        && request.resource.data.status == "new"
        && request.resource.data.customer.name.size() > 0
        && request.resource.data.customer.name.size() <= 200
        && request.resource.data.customer.email.size() > 0
        && request.resource.data.customer.email.size() <= 320
        && request.resource.data.customer.phone.size() > 0
        && request.resource.data.customer.phone.size() <= 30;
      allow read: if isAdmin() || (request.auth != null && resource.data.customer.email == request.auth.token.email);
      allow update, delete: if isAdmin();
    }

    // ----------------------------------------------------------------------
    // PUBLIC KOLEKSİYONLAR — herkes okuyabilir, sadece admin yazabilir
    // ----------------------------------------------------------------------
    match /mindid_portfolio/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mindid_faq/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mindid_team/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mindid_avatarSamples/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mindid_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mindid_pricing/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blog: sadece yayınlananlar herkese açık, admin her şeyi görebilir
    match /mindid_blog/{docId} {
      allow read: if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // Leads: exit-intent popup ve formlardan gelen potansiyel müşteriler
    // Herkes oluşturabilir (popup formu), sadece admin okuyabilir/güncelleyebilir
    match /mindid_leads/{leadId} {
      allow create: if request.resource.data.keys().hasAll(["name", "source", "page", "status", "createdAt", "updatedAt"])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.status == "new"
        && (
          !("phone" in request.resource.data)
          || (request.resource.data.phone is string && request.resource.data.phone.size() <= 30)
        )
        && (
          !("email" in request.resource.data)
          || (request.resource.data.email is string && request.resource.data.email.size() <= 320)
        );
      allow read, update, delete: if isAdmin();
    }

    // Analytics: sayfa görüntülemeleri için herkes yazabilir, sadece admin okuyabilir
    match /mindid_analytics/{docId} {
      allow create, update: if request.resource.data.keys().hasAll(["date", "pageViews"])
        && request.resource.data.date is string
        && request.resource.data.date.size() == 10;
      allow read: if isAdmin();
    }

    // ----------------------------------------------------------------------
    // MÜŞTERİ SİSTEMİ (SaaS)
    // Customers can read/update their own profile, admins can do anything
    // ----------------------------------------------------------------------
    match /mindid_customers/{customerId} {
      allow create: if request.auth != null
        && request.auth.uid == customerId
        && request.resource.data.keys().hasAll(["uid", "email", "name", "plan", "credits", "createdAt"])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.plan == "free"
        && request.resource.data.credits == 0;
      allow read: if request.auth != null && request.auth.uid == customerId;
      allow update: if request.auth != null && request.auth.uid == customerId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["plan", "credits", "totalSpent"]);
      allow read, write: if isAdmin();
    }

    // Müşteri siparişlerini okuyabilmesi için order rules güncelleme
    // (Mevcut create ve admin kuralları korunuyor, müşteri read ekleniyor)

    // Bildirimler: müşteri kendi bildirimlerini okuyabilir
    match /mindid_notifications/{notifId} {
      allow read: if request.auth != null
        && resource.data.customerId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.customerId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"]);
      allow create, delete: if isAdmin();
    }

    // Ödeme kayıtları: müşteri kendi ödemelerini görebilir
    match /mindid_payments/{paymentId} {
      allow read: if request.auth != null
        && resource.data.customerId == request.auth.uid;
      allow write: if isAdmin();
    }

    // Müşteri dosyaları: müşteri kendi dosyalarını görebilir
    match /mindid_customer_files/{fileId} {
      allow read: if request.auth != null
        && resource.data.customerId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.customerId == request.auth.uid;
      allow write: if isAdmin();
    }
  }
}
