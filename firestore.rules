rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Orders: anyone can create (with validation), only admins can read/update/delete
    match /mindid_orders/{orderId} {
      allow create: if request.resource.data.keys().hasAll(["customer", "serviceId", "serviceName", "pricing", "status", "createdAt"])
        && request.resource.data.customer is map
        && request.resource.data.customer.name is string
        && request.resource.data.customer.email is string
        && request.resource.data.customer.phone is string
        && request.resource.data.status == "new"
        && request.resource.data.customer.name.size() > 0
        && request.resource.data.customer.name.size() <= 200
        && request.resource.data.customer.email.size() > 0
        && request.resource.data.customer.email.size() <= 320
        && request.resource.data.customer.phone.size() > 0
        && request.resource.data.customer.phone.size() <= 30;
      allow read, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Public collections: read-only for everyone
    match /mindid_portfolio/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /mindid_faq/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /mindid_team/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /mindid_avatarSamples/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /mindid_settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /mindid_pricing/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Blog: only published posts public read, admin full access
    match /mindid_blog/{docId} {
      allow read: if resource.data.published == true
        || (request.auth != null
          && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Leads: exit-intent popup ve formlardan gelen potansiyel müşteriler
    // Herkes oluşturabilir (popup formu), sadece admin okuyabilir/güncelleyebilir
    match /mindid_leads/{leadId} {
      allow create: if request.resource.data.keys().hasAll(["name", "source", "page", "status", "createdAt", "updatedAt"])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.status == "new"
        && (
          !("phone" in request.resource.data)
          || (request.resource.data.phone is string && request.resource.data.phone.size() <= 30)
        )
        && (
          !("email" in request.resource.data)
          || (request.resource.data.email is string && request.resource.data.email.size() <= 320)
        );
      allow read, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Analytics: sayfa görüntülemeleri için herkes yazabilir, sadece admin okuyabilir
    // Not: Aynı belgeyi artırımlı güncellemek için create+update gerekli
    match /mindid_analytics/{docId} {
      allow create, update: if request.resource.data.keys().hasAll(["date", "pageViews"])
        && request.resource.data.date is string
        && request.resource.data.date.size() == 10;
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admin docs
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }
  }
}
